generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model User {
  id            String    @id @db.Uuid
  email         String?   @unique
  name          String?
  image         String?
  type          String?   @default("USER")
  provider      String?
  providerId    String?   @map("provider_id")
  emailVerified Boolean?  @default(false) @map("email_verified")
  createdAt     DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  adminUser AdminUser?

  @@map("users")
  @@schema("public")
}

model AdminUser {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @map("user_id") @db.Uuid
  role      String   @default("VIEWER")
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([role])
  @@map("admin_users")
  @@schema("public")
}

model Notification {
  id                                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                               String    @map("user_id") @db.Uuid
  type                                 String    @db.VarChar(50)
  title                                String
  message                              String
  priority                             String?   @default("medium") @db.VarChar(20)
  read                                 Boolean?  @default(false)
  readAt                               DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt                            DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                            DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  data                                 Json?     @default("{}") @map("data")
  link                                 String?
  senderId                             String?   @map("sender_id") @db.Uuid
  senderName                           String?   @map("sender_name")
  senderAvatar                         String?   @map("sender_avatar")
  expiresAt                            DateTime? @map("expires_at") @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)], map: "idx_notifications_created_at")
  @@index([priority], map: "idx_notifications_priority")
  @@index([read], map: "idx_notifications_read")
  @@index([type], map: "idx_notifications_type")
  @@index([userId], map: "idx_notifications_user_id")
  @@index([userId, read], map: "idx_notifications_user_read")
  @@map("notifications")
  @@schema("public")
}

model NotificationPreference {
  userId     String    @id @map("user_id") @db.Uuid
  email      Boolean?  @default(true)
  push       Boolean?  @default(true)
  inApp      Boolean?  @default(true) @map("in_app")
  types      Json?     @default("{}")
  quietHours Json?     @map("quiet_hours")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("notification_preferences")
  @@schema("public")
}

model AuditLog {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  action    String
  ip        String?
  userAgent String?   @map("user_agent")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("audit_logs")
  @@schema("public")
}

model Job {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  department  String   @db.VarChar(100)
  type        String   @db.VarChar(50)
  location    String   @db.VarChar(200)
  salary      String?  @db.VarChar(100)
  salaryMin   Int?
  salaryMax   Int?
  skills      String[]
  description String   @db.Text
  icon        String?  @db.VarChar(500)
  status      JobStatus @default(ACTIVE)
  applicationUrl String? @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  applications JobApplication[]

  @@schema("public")
  @@map("jobs")
}

model Internship {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(200)
  department  String   @db.VarChar(100)
  duration    String   @db.VarChar(50)
  location    String   @db.VarChar(200)
  stipend     String?  @db.VarChar(100)
  stipendAmount Int?
  skills      String[]
  description String   @db.Text
  icon        String?  @db.VarChar(500)
  status      JobStatus @default(ACTIVE)
  applicationUrl String? @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  applications InternshipApplication[]

  @@schema("public")
  @@map("internships")
}

model JobApplication {
  id          String            @id @default(uuid()) @db.Uuid
  jobId       String            @map("job_id") @db.Uuid
  userId      String?           @map("user_id") @db.Uuid
  name        String            @db.VarChar(200)
  email       String            @db.VarChar(320)
  phone       String?           @db.VarChar(30)
  currentCompany    String?   @map("current_company") @db.VarChar(200)
  currentPosition   String?   @map("current_position") @db.VarChar(200)
  yearsOfExperience String?   @map("years_of_experience") @db.VarChar(20)
  linkedInUrl       String?   @map("linkedin_url") @db.VarChar(500)
  portfolioUrl      String?   @map("portfolio_url") @db.VarChar(500)
  resumeUrl   String?           @map("resume_url") @db.VarChar(500)
  coverLetter String?           @map("cover_letter") @db.Text
  salaryExpectation  String?  @map("salary_expectation") @db.VarChar(100)
  startDate          DateTime? @map("start_date") @db.Date
  workAuthorization  String?  @map("work_authorization") @db.VarChar(100)
  referralSource     String?  @map("referral_source") @db.VarChar(200)
  additionalInfo     String?  @map("additional_info") @db.Text
  status          ApplicationStatus @default(PENDING)
  interviewerName   String?   @map("interviewer_name") @db.VarChar(200)
  interviewDate     DateTime? @map("interview_date") @db.Date
  interviewerFeedback String? @map("interviewer_feedback") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  job  Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@schema("public")
  @@map("job_applications")
}

model InternshipApplication {
  id           String            @id @default(uuid()) @db.Uuid
  internshipId String            @map("internship_id") @db.Uuid
  userId       String?           @map("user_id") @db.Uuid
  name         String            @db.VarChar(200)
  email        String            @db.VarChar(320)
  phone        String?           @db.VarChar(30)
  university          String    @map("university") @db.VarChar(200)
  major               String    @map("major") @db.VarChar(200)
  yearOfStudy         String    @map("year_of_study") @db.VarChar(50)
  graduationDate      DateTime? @map("graduation_date") @db.Date
  gpa                 String?   @db.VarChar(10)
  linkedInUrl         String?   @map("linkedin_url") @db.VarChar(500)
  githubUrl           String?   @map("github_url") @db.VarChar(500)
  availableStartDate  DateTime? @map("available_start_date") @db.Date
  availabilityDuration String?  @map("availability_duration") @db.VarChar(50)
  workAuthorization   String?   @map("work_authorization") @db.VarChar(100)
  referralSource      String?   @map("referral_source") @db.VarChar(200)
  additionalInfo      String?   @map("additional_info") @db.Text
  resumeUrl    String?           @map("resume_url") @db.VarChar(500)
  coverLetter  String?           @map("cover_letter") @db.Text
  status          ApplicationStatus @default(PENDING)
  interviewerName   String?   @map("interviewer_name") @db.VarChar(200)
  interviewDate     DateTime? @map("interview_date") @db.Date
  interviewerFeedback String? @map("interviewer_feedback") @db.Text
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  internship Internship @relation(fields: [internshipId], references: [id], onDelete: Cascade)

  @@schema("public")
  @@map("internship_applications")
}

model Interviewer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  @@schema("public")
  @@map("interviewers")
}

// ─── LMS Models ─────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  courses     Course[]

  @@map("categories")
  @@schema("public")
}

model Course {
  id            String       @id @default(uuid()) @db.Uuid
  title         String       @db.VarChar(300)
  slug          String       @unique @db.VarChar(300)
  description   String?      @db.Text
  thumbnail     String?      @db.VarChar(500)
  categoryId    String?      @map("category_id") @db.Uuid
  level         String?      @db.VarChar(50)
  duration      Int?
  instructorId  String       @map("instructor_id") @db.Uuid
  price         Decimal?     @db.Decimal(10, 2)
  isFree        Boolean?     @default(false) @map("is_free")
  status        CourseStatus @default(DRAFT)
  isComplete    Boolean      @default(false) @map("is_complete")
  publishedAt   DateTime?    @map("published_at") @db.Timestamptz(6)
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  modules       Module[]
  enrollments   Enrollment[]
  certificates  Certificate[]
  reviews       Review[]
  wishlists     Wishlist[]
  category      Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([status])
  @@index([instructorId])
  @@map("courses")
  @@schema("public")
}

model Module {
  id        String   @id @default(uuid()) @db.Uuid
  courseId   String   @map("course_id") @db.Uuid
  title     String   @db.VarChar(300)
  sortOrder Int      @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([courseId, sortOrder])
  @@map("modules")
  @@schema("public")
}

model Lesson {
  id          String     @id @default(uuid()) @db.Uuid
  moduleId     String     @map("module_id") @db.Uuid
  title       String     @db.VarChar(300)
  description String?    @db.Text
  type        LessonType @default(TEXT)
  content     Json?
  videoUrl    String?    @map("video_url") @db.VarChar(500)
  attachments Json?      @default("[]")
  duration    Int?
  sortOrder   Int        @map("sort_order")
  isPublished Boolean    @default(false) @map("is_published")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    Progress[]
  quizzes     Quiz[]

  @@index([moduleId, sortOrder])
  @@map("lessons")
  @@schema("public")
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid
  courseId      String         @map("course_id") @db.Uuid
  studentId     String         @map("student_id") @db.Uuid
  status      EnrollmentStatus @default(ACTIVE)
  progress    Float            @default(0)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  course      Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([studentId])
  @@map("enrollments")
  @@schema("public")
}

model Progress {
  id          String   @id @default(uuid()) @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  lessonId     String   @map("lesson_id") @db.Uuid
  completed   Boolean  @default(false)
  score       Float?
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@map("progress")
  @@schema("public")
}

model Quiz {
  id                String   @id @default(uuid()) @db.Uuid
  lessonId           String   @map("lesson_id") @db.Uuid
  title             String   @db.VarChar(300)
  description       String?  @db.Text
  passingScore      Int      @default(70) @map("passing_score")
  timeLimit         Int?     @map("time_limit")
  maxAttempts       Int      @default(1) @map("max_attempts")
  shuffleQuestions  Boolean  @default(false) @map("shuffle_questions")
  showResults       Boolean  @default(true) @map("show_results")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  lesson            Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions         Question[]
  attempts          QuizAttempt[]

  @@index([lessonId])
  @@map("quizzes")
  @@schema("public")
}

model Question {
  id            String   @id @default(uuid()) @db.Uuid
  quizId         String   @map("quiz_id") @db.Uuid
  type          String   @db.VarChar(50)
  question      String   @db.Text
  options       Json?    @default("[]")
  correctAnswer Json     @map("correct_answer")
  points        Int      @default(1)
  sortOrder     Int      @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
  @@map("questions")
  @@schema("public")
}

model QuizAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  quizId       String   @map("quiz_id") @db.Uuid
  studentId    String   @map("student_id") @db.Uuid
  score       Float?
  passed      Boolean?
  answers     Json?    @default("[]")
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, studentId])
  @@map("quiz_attempts")
  @@schema("public")
}

model Certificate {
  id              String   @id @default(uuid()) @db.Uuid
  courseId          String   @map("course_id") @db.Uuid
  studentId         String   @map("student_id") @db.Uuid
  certificateUrl   String?  @map("certificate_url") @db.VarChar(500)
  issuedAt         DateTime @default(now()) @map("issued_at")
  createdAt        DateTime @default(now()) @map("created_at")

  course           Course   @relation(fields: [courseId], references: [id])

  @@unique([courseId, studentId])
  @@map("certificates")
  @@schema("public")
}

model Review {
  id        String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  rating    Int      @db.SmallInt
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
  @@index([courseId])
  @@map("reviews")
  @@schema("public")
}

model Wishlist {
  id        String   @id @default(uuid()) @db.Uuid
  studentId   String   @map("student_id") @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@map("wishlists")
  @@schema("public")
}

enum JobStatus {
  ACTIVE
  CLOSED
  DRAFT

  @@schema("public")
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  ACCEPTED

  @@schema("public")
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED

  @@schema("public")
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT

  @@schema("public")
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED

  @@schema("public")
}

